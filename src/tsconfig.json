{
  "compilerOptions": {
    "target": "ES2018",
    "module": "commonjs",
    "outDir": ".",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"],
  },
  "include": ["main.ts"],
  "exclude": ["node_modules"],
}
